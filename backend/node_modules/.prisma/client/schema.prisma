datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Tenant {
  id             String        @id @default(uuid())
  name           String
  logo           String?
  primaryColor   String        @default("#0f172a")
  secondaryColor String        @default("#3b82f6")
  domain         String        @unique
  schedule       String        @default("[]") // JSON representation of working hours
  tableCount     Int           @default(0)
  capacity       Int           @default(0)
  configuration  String        @default("{}") // JSON config: SMTP, WhatsApp, GA, Pixel
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  users          User[]
  tables         Table[]
  reservas       Reservation[]
  clients        Client[]
  waitlist       Waitlist[]
  configs        Config[]
  auditLogs      AuditLog[]
  menuItems      MenuItem[]
}

model User {
  id              String     @id @default(uuid())
  email           String     @unique
  passwordHash    String
  firstName       String
  lastName        String
  role            String // SUPER_ADMIN, ADMIN, RECEPTION, WAITER, CASHIER, CUSTOMER
  phone           String?
  tenantId        String? // Nullable for SUPER_ADMIN
  tenant          Tenant?    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  is2faEnabled    Boolean    @default(false)
  twoFactorSecret String?
  isVerified      Boolean    @default(false)
  refreshToken    String?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  auditLogs       AuditLog[]
}

model Table {
  id        String        @id @default(uuid())
  name      String
  capacity  Int
  status    String        @default("AVAILABLE") // AVAILABLE, RESERVED, OCCUPIED, CLEANING, OUT_OF_SERVICE
  x         Int           @default(0)
  y         Int           @default(0)
  width     Int           @default(100)
  height    Int           @default(100)
  shape     String        @default("rectangular") // rectangular, round
  zone      String        @default("MAIN") // MAIN, TERRACE, VIP, BAR
  tenantId  String
  tenant    Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  reservas  Reservation[]
}

model Reservation {
  id                    String   @id @default(uuid())
  clientName            String
  clientPhone           String
  clientEmail           String
  dateTime              DateTime
  partySize             Int
  zone                  String   @default("MAIN") // MAIN, TERRACE, VIP, BAR
  status                String   @default("PENDING") // PENDING, CONFIRMED, COMPLETED, CANCELLED, NO_SHOW
  celebration           String   @default("NONE") // NONE, BIRTHDAY, ANNIVERSARY, OTHER
  notes                 String?
  tableId               String?
  table                 Table?   @relation(fields: [tableId], references: [id], onDelete: SetNull)
  tenantId              String
  tenant                Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  clientId              String?
  client                Client?  @relation(fields: [clientId], references: [id], onDelete: SetNull)
  isWaitlist            Boolean  @default(false)
  tablePurchased        Boolean  @default(false)
  purchaseAmount        Float?
  purchasePaymentMethod String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}

model Client {
  id          String        @id @default(uuid())
  name        String
  phone       String
  email       String
  birthday    DateTime?
  anniversary DateTime?
  notes       String?
  tags        String        @default("[]") // JSON string array of tags (e.g. VIP, Frecuente, Nuevo)
  isVip       Boolean       @default(false)
  tenantId    String
  tenant      Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  reservas    Reservation[]

  @@unique([email, tenantId])
}

model Waitlist {
  id          String   @id @default(uuid())
  clientName  String
  clientPhone String
  clientEmail String
  partySize   Int
  zone        String   @default("MAIN")
  notes       String?
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Config {
  id        String   @id @default(uuid())
  key       String
  value     String
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([key, tenantId])
}

model AuditLog {
  id        String   @id @default(uuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  action    String
  details   String // JSON string details
  ipAddress String?
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}

model MenuItem {
  id          String   @id @default(uuid())
  name        String
  description String?
  price       Float
  category    String // ENTRADA, PLATO_FUERTE, POSTRE, BEBIDA
  imageUrl    String?
  available   Boolean  @default(true)
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
